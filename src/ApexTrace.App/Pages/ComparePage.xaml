<UserControl x:Class="ApexTrace.App.Pages.ComparePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <Grid><Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal"><TextBlock Text="双圈对比" Style="{StaticResource PageTitleStyle}"/><Border Background="#12345B" CornerRadius="5" Padding="16,8" Margin="24,0,8,14"><TextBlock Text="当前：真实 LMU 片段" Foreground="{StaticResource BlueHighlightBrush}"/></Border><Border Background="#3B2B17" CornerRadius="5" Padding="16,8" Margin="0,0,8,14"><TextBlock Text="参考：不可用" Foreground="#FF9D2E"/></Border></StackPanel>
        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="1.2*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="1.2*"/><RowDefinition Height="1*"/></Grid.RowDefinitions>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="赛道地图  |  蓝色当前片段 / 橙色参考圈" FontWeight="SemiBold"/><r:TrackCanvasControl Grid.Row="1" TrackPoints="{Binding TrackPoints}" CurrentProgress="{Binding ReplayProgress}" Margin="0,10,0,0"/></Grid></Border>
            <Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="130"/><RowDefinition Height="*"/></Grid.RowDefinitions><UniformGrid Columns="4"><Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="总圈速差" Style="{StaticResource LabelStyle}"/><TextBlock Text="--" FontSize="31" Foreground="{StaticResource TextSecondaryBrush}"/><TextBlock Text="需两个完整圈" Style="{StaticResource LabelStyle}"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="S1" Style="{StaticResource LabelStyle}"/><TextBlock Text="--" FontSize="29"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="S2" Style="{StaticResource LabelStyle}"/><TextBlock Text="--" FontSize="29"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,0,8"><StackPanel><TextBlock Text="S3" Style="{StaticResource LabelStyle}"/><TextBlock Text="--" FontSize="29"/></StackPanel></Border></UniformGrid><Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,10"><StackPanel><TextBlock Text="速度对比" FontWeight="SemiBold"/><TextBlock Text="没有两个完整有效圈，因此不计算 Delta，也不绘制虚构参考曲线。" Foreground="{StaticResource WarningAmberBrush}" TextWrapping="Wrap" Margin="0,22,0,18"/><ProgressBar Value="0" Maximum="1"/><TextBlock Text="符号定义：正值 = 当前圈更慢；负值 = 当前圈更快" Style="{StaticResource LabelStyle}" Margin="0,18,0,0"/></StackPanel></Border></Grid>
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="弯道逐段对比" FontWeight="SemiBold"/><TextBlock Text="T1 — T20 将在至少两个完整圈完成距离重采样后显示。" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,18,0,0"/></StackPanel></Border>
            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="踏板输入对比" FontWeight="SemiBold"/><TextBlock Text="真实片段包含油门、刹车与方向输入；参考圈缺失，图表安全降级。" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,18,0,12"/><ProgressBar Value="{Binding ThrottleValue}" Maximum="1" Foreground="{StaticResource SuccessGreenBrush}" Margin="0,8"/><ProgressBar Value="{Binding BrakeValue}" Maximum="1" Foreground="{StaticResource DangerRedBrush}" Margin="0,8"/></StackPanel></Border>
        </Grid>
    </Grid>
</UserControl>
