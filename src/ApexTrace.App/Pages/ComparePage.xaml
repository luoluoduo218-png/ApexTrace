<UserControl x:Class="ApexTrace.App.Pages.ComparePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="*"/></Grid.RowDefinitions>

        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="220"/><ColumnDefinition Width="54"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <TextBlock Text="参考圈（橙色）" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding ComparisonLaps}" SelectedItem="{Binding SelectedComparisonReferenceLap, Mode=TwoWay}" Style="{StaticResource DarkComboBoxStyle}">
                <ComboBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding LapNumber, StringFormat=圈 {0}}" FontWeight="SemiBold"/><TextBlock Text="{Binding LapTimeSeconds, Converter={StaticResource SecondsToLapTime}}" Foreground="#FF9D2E" Margin="12,0,0,0"/></StackPanel></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="2" Content="⇄" Command="{Binding SwapComparisonLapsCommand}" Style="{StaticResource IconButtonStyle}" Margin="6,0" FontSize="19" ToolTip="交换当前圈和参考圈"/>
            <TextBlock Grid.Column="3" Text="当前圈（蓝色）" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0"/>
            <ComboBox Grid.Column="4" ItemsSource="{Binding ComparisonLaps}" SelectedItem="{Binding SelectedComparisonCurrentLap, Mode=TwoWay}" Style="{StaticResource DarkComboBoxStyle}">
                <ComboBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding LapNumber, StringFormat=圈 {0}}" FontWeight="SemiBold"/><TextBlock Text="{Binding LapTimeSeconds, Converter={StaticResource SecondsToLapTime}}" Foreground="{StaticResource BlueHighlightBrush}" Margin="12,0,0,0"/></StackPanel></DataTemplate></ComboBox.ItemTemplate>
            </ComboBox>
            <TextBlock Grid.Column="5" Text="正值表示当前圈慢于参考圈，负值表示当前圈更快" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="0.93*"/><ColumnDefinition Width="1.17*"/></Grid.ColumnDefinitions>

            <Grid Margin="0,0,10,0">
                <Grid.RowDefinitions><RowDefinition Height="1.18*"/><RowDefinition Height="0.82*"/></Grid.RowDefinitions>
                <Border Style="{StaticResource CardStyle}" Padding="10" Margin="0,0,0,8">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid><TextBlock Text="{Binding TrackName, StringFormat=赛道地图  |  {0}}" FontSize="16" FontWeight="SemiBold" Width="320" TextTrimming="CharacterEllipsis" HorizontalAlignment="Left"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Border Width="24" Height="3" Background="{StaticResource BlueHighlightBrush}" Margin="0,8,6,0"/><TextBlock Text="当前圈" Foreground="{StaticResource TextSecondaryBrush}"/><Border Width="24" Height="3" Background="#FF9D2E" Margin="12,8,6,0"/><TextBlock Text="参考圈" Foreground="{StaticResource TextSecondaryBrush}"/></StackPanel></Grid>
                        <r:TrackCanvasControl Grid.Row="1" TrackPoints="{Binding ComparisonCurrentPoints}" ReferencePoints="{Binding ComparisonReferencePoints}" ReferenceColor="#FF9D2E" Margin="0,8,0,0"/>
                    </Grid>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="10">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid><TextBlock Text="弯道逐段对比" FontSize="15" FontWeight="SemiBold"/><TextBlock Text="{Binding CornerAnalyses.Count, StringFormat=识别 {0} 个转向区间}" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right"/></Grid>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding CornerAnalyses}" Margin="0,7,0,0" RowHeight="23" ColumnHeaderHeight="25" FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="弯道" Binding="{Binding Name}" Width="0.55*"/>
                                <DataGridTextColumn Header="类型/距离" Binding="{Binding DistanceText}" Width="1.25*"/>
                                <DataGridTextColumn Header="时间差" Binding="{Binding DeltaText}" Width="0.8*"/>
                                <DataGridTextColumn Header="刹车点" Binding="{Binding BrakeStartMeters, StringFormat={}{0:F0} m}" Width="0.9*"/>
                                <DataGridTextColumn Header="入弯→弯心→出弯" Binding="{Binding SpeedText}" Width="1.8*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Grid.Row="2" Text="{Binding LapComparison.Diagnostic}" Foreground="{StaticResource WarningAmberBrush}" FontSize="11" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions><RowDefinition Height="0.7*"/><RowDefinition Height="0.48*"/><RowDefinition Height="0.91*"/><RowDefinition Height="0.91*"/></Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.18*"/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,7,7"><StackPanel><TextBlock Text="总圈速差" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding LapDeltaText}" FontSize="30" FontWeight="SemiBold" Foreground="{StaticResource DangerRedBrush}" Margin="0,4,0,0"/><StackPanel Orientation="Horizontal" Margin="0,4,0,0"><TextBlock Text="当前  " Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/><TextBlock Text="{Binding SelectedComparisonCurrentLap.LapTimeSeconds, Converter={StaticResource SecondsToLapTime}, Mode=OneWay}" Foreground="{StaticResource BlueHighlightBrush}" FontSize="10"/></StackPanel><StackPanel Orientation="Horizontal"><TextBlock Text="参考  " Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/><TextBlock Text="{Binding SelectedComparisonReferenceLap.LapTimeSeconds, Converter={StaticResource SecondsToLapTime}, Mode=OneWay}" Foreground="#FF9D2E" FontSize="10"/></StackPanel></StackPanel></Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,7,7"><StackPanel><TextBlock Text="S1" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding Sector1DeltaText}" FontSize="20" Foreground="{StaticResource DangerRedBrush}"/><TextBlock Text="{Binding Sector1CurrentText}" Foreground="{StaticResource BlueHighlightBrush}" FontSize="11"/><TextBlock Text="{Binding Sector1ReferenceText}" Foreground="#FF9D2E" FontSize="11"/></StackPanel></Border>
                    <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,7,7"><StackPanel><TextBlock Text="S2" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding Sector2DeltaText}" FontSize="20" Foreground="{StaticResource DangerRedBrush}"/><TextBlock Text="{Binding Sector2CurrentText}" Foreground="{StaticResource BlueHighlightBrush}" FontSize="11"/><TextBlock Text="{Binding Sector2ReferenceText}" Foreground="#FF9D2E" FontSize="11"/></StackPanel></Border>
                    <Border Grid.Column="3" Style="{StaticResource CardStyle}" Margin="0,0,0,7"><StackPanel><TextBlock Text="S3" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding Sector3DeltaText}" FontSize="20" Foreground="{StaticResource SuccessGreenBrush}"/><TextBlock Text="{Binding Sector3CurrentText}" Foreground="{StaticResource BlueHighlightBrush}" FontSize="11"/><TextBlock Text="{Binding Sector3ReferenceText}" Foreground="#FF9D2E" FontSize="11"/></StackPanel></Border>
                </Grid>
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,7">
                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,6,0"><StackPanel><TextBlock Text="刹车点差异" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding BrakePointDifferenceText}" FontSize="18" Foreground="{StaticResource DangerRedBrush}"/><TextBlock Text="{Binding BrakePointDifferenceHint}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/></StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,6,0"><StackPanel><TextBlock Text="全油门占比差异" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding FullThrottleDifferenceText}" FontSize="18" Foreground="{StaticResource SuccessGreenBrush}"/><TextBlock Text="{Binding FullThrottleDifferenceHint}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/></StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="12" Margin="0,0,6,0"><StackPanel><TextBlock Text="最低速度差异" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding MinimumSpeedDifferenceText}" FontSize="18" Foreground="{StaticResource DangerRedBrush}"/><TextBlock Text="{Binding MinimumSpeedDifferenceHint}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/></StackPanel></Border>
                    <Border Style="{StaticResource CardStyle}" Padding="12"><StackPanel><TextBlock Text="出圈速度差异" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding ExitSpeedDifferenceText}" FontSize="18" Foreground="{StaticResource SuccessGreenBrush}"/><TextBlock Text="{Binding ExitSpeedDifferenceHint}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/></StackPanel></Border>
                </UniformGrid>
                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="10" Margin="0,0,0,7">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="22"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="速度对比" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"><Border Width="24" Height="3" Background="{StaticResource BlueHighlightBrush}" Margin="0,7,5,0"/><TextBlock Text="当前圈" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/><Border Width="24" Height="3" Background="#FF9D2E" Margin="15,7,5,0"/><TextBlock Text="参考圈" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><TextBlock Text="{Binding ComparisonMaxSpeedText}" Style="{StaticResource LabelStyle}" VerticalAlignment="Center"/><Button Content="⛶  放大" Tag="Speed" Click="ExpandChart_OnClick" Style="{StaticResource IconButtonStyle}" Padding="9,3" Margin="10,-4,0,-2"/></StackPanel>
                        </Grid>
                        <r:LapComparisonChartControl Grid.Row="1" CurrentSamples="{Binding ComparisonCurrentSamples}" ReferenceSamples="{Binding ComparisonReferenceSamples}"/>
                    </Grid>
                </Border>
                <Border Grid.Row="3" Style="{StaticResource CardStyle}" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="22"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="踏板输入对比" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Border Width="24" Height="3" Background="{StaticResource BlueHighlightBrush}" Margin="0,7,5,0"/><TextBlock Text="当前圈" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <Border Width="24" Height="3" Background="#FF9D2E" Margin="15,7,5,0"/><TextBlock Text="参考圈" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="实线油门 / 虚线刹车" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="15,0,0,0"/>
                            </StackPanel>
                            <Button Content="⛶  放大" Tag="Pedals" Click="ExpandChart_OnClick" Style="{StaticResource IconButtonStyle}" Padding="9,3" Margin="0,-4,0,-2" HorizontalAlignment="Right"/>
                        </Grid>
                        <r:LapComparisonChartControl Grid.Row="1" CurrentSamples="{Binding ComparisonCurrentSamples}" ReferenceSamples="{Binding ComparisonReferenceSamples}"
                                                     ShowPedals="True"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="ExpandedOverlay" Grid.RowSpan="2" Visibility="Collapsed" Background="#F207121E" Panel.ZIndex="20">
            <Border Style="{StaticResource CardStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Grid>
                        <TextBlock x:Name="ExpandedTitle" FontSize="21" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="32" Height="4" Background="{StaticResource BlueHighlightBrush}" Margin="0,7,7,0"/><TextBlock Text="当前圈" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <Border Width="32" Height="4" Background="#FF9D2E" Margin="22,7,7,0"/><TextBlock Text="参考圈" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock x:Name="ExpandedHint" Foreground="{StaticResource TextSecondaryBrush}" Margin="22,0,0,0"/>
                        </StackPanel>
                        <Button Content="×  关闭" Click="CloseExpandedChart_OnClick" Style="{StaticResource BaseButtonStyle}" Padding="14,7" HorizontalAlignment="Right"/>
                    </Grid>
                    <r:LapComparisonChartControl x:Name="ExpandedChart" Grid.Row="1" Margin="0,12,0,0"
                                                 CurrentSamples="{Binding ComparisonCurrentSamples}" ReferenceSamples="{Binding ComparisonReferenceSamples}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
