<UserControl x:Class="ApexTrace.App.Pages.CornersPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="72"/><RowDefinition Height="*"/><RowDefinition Height="44"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="弯道分析" Style="{StaticResource PageTitleStyle}" Margin="0"/><TextBlock Text="由完整圈的方向、速度和制动信号自动识别；选择一行查看实际局部走线" Foreground="{StaticResource TextSecondaryBrush}"/></StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="已识别弯道 / 转向区间" FontSize="17" FontWeight="SemiBold"/>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding CornerAnalyses}" SelectedItem="{Binding SelectedCorner, Mode=TwoWay}" Margin="0,12,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="弯道" Binding="{Binding Name}" Width="0.55*"/>
                            <DataGridTextColumn Header="距离" Binding="{Binding DistanceText}" Width="1.2*"/>
                            <DataGridTextColumn Header="进/弯心/出弯" Binding="{Binding SpeedText}" Width="1.8*"/>
                            <DataGridTextColumn Header="刹车点" Binding="{Binding BrakeStartMeters, StringFormat=F0}" Width="0.75*"/>
                            <DataGridTextColumn Header="对最佳圈" Binding="{Binding DeltaText}" Width="0.8*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            <Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="1.15*"/><RowDefinition Height="210"/></Grid.RowDefinitions>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="{Binding SelectedCornerTitle}" FontSize="17" FontWeight="SemiBold"/><r:TrackCanvasControl Grid.Row="1" TrackPoints="{Binding SelectedCornerTrackPoints}" Margin="0,12,0,0"/></Grid></Border>
                <Border Grid.Row="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="本弯相对最佳圈" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SelectedCornerLossText}" FontSize="34" Foreground="{StaticResource WarningAmberBrush}" Margin="0,8"/><TextBlock Text="进弯 → 弯心最低 → 出弯" FontWeight="SemiBold" Margin="0,4"/><TextBlock Text="{Binding SelectedCornerSpeedText}" Foreground="{StaticResource BlueHighlightBrush}" FontSize="17"/><TextBlock Text="正值表示当前圈在这个距离区间更慢。弯道边界由方向信号自动推断，可用于定位，不等同官方弯号。" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,0"/></StackPanel></Border>
            </Grid>
        </Grid>
        <TextBlock Grid.Row="2" Text="提示：若有效圈不足两个，仍可查看单圈弯道数据，但不会显示对比时间。" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
    </Grid>
</UserControl>
