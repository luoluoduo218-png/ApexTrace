<UserControl x:Class="ApexTrace.App.Pages.CornersPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <Grid><Grid.RowDefinitions><RowDefinition Height="72"/><RowDefinition Height="48"/><RowDefinition Height="*"/><RowDefinition Height="44"/></Grid.RowDefinitions><StackPanel><TextBlock Text="弯道分析" Style="{StaticResource PageTitleStyle}" Margin="0"/><TextBlock Text="逐弯分析表现，发现问题并提升圈速" Foreground="{StaticResource TextSecondaryBrush}"/></StackPanel><ItemsControl Grid.Row="1"><ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="10"/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.Items><TextBlock Text="T1"/><TextBlock Text="T2"/><TextBlock Text="T3"/><TextBlock Text="T4"/><TextBlock Text="T5"/><TextBlock Text="T6"/><TextBlock Text="T7" Foreground="{StaticResource BlueHighlightBrush}"/><TextBlock Text="T8"/><TextBlock Text="T9"/><TextBlock Text="T10"/></ItemsControl.Items></ItemsControl>
        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="1.25*"/></Grid.ColumnDefinitions><Border Style="{StaticResource CardStyle}" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="局部赛道 · 真实轨迹片段" FontSize="17" FontWeight="SemiBold"/><r:TrackCanvasControl Grid.Row="1" TrackPoints="{Binding TrackPoints}" CurrentProgress="{Binding ReplayProgress}" Margin="0,12,0,0"/></Grid></Border><Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="190"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border Style="{StaticResource CardStyle}" Margin="0,0,0,10"><StackPanel><TextBlock Text="本弯损失时间" Style="{StaticResource LabelStyle}"/><TextBlock Text="不计算" FontSize="34" Foreground="{StaticResource WarningAmberBrush}" Margin="0,8"/><TextBlock Text="主要问题" FontWeight="SemiBold" Margin="0,8,0,4"/><TextBlock Text="当前数据不是完整圈，无法建立可靠参考圈和弯道边界。" TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}"/><TextBlock Text="这是有意的安全降级，不会猜测建议。" Foreground="{StaticResource SuccessGreenBrush}" Margin="0,8,0,0"/></StackPanel></Border><Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="速度对比" FontWeight="SemiBold"/><TextBlock Text="等待完整参考圈" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,18"/><ProgressBar Value="0" Maximum="1"/></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="刹车对比" FontWeight="SemiBold"/><TextBlock Text="当前真实刹车输入" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,18,0,10"/><ProgressBar Value="{Binding BrakeValue}" Maximum="1" Foreground="{StaticResource DangerRedBrush}"/></StackPanel></Border></Grid></Grid></Grid>
        <TextBlock Grid.Row="3" Text="提示：建议仅在确定性事件、完整圈对齐和足够样本同时满足时生成。" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
    </Grid>
</UserControl>
