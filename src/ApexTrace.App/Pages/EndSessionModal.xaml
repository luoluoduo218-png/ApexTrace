<UserControl x:Class="ApexTrace.App.Pages.EndSessionModal" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Width="640" Background="#101B28" BorderBrush="#39495C" BorderThickness="1" CornerRadius="12" Padding="30">
        <Border.Effect><DropShadowEffect BlurRadius="30" ShadowDepth="8" Opacity="0.55" Color="#000000"/></Border.Effect>
        <StackPanel>
            <TextBlock Text="结束本次记录？" Style="{StaticResource PageTitleStyle}"/>
            <TextBlock Text="保存到记录库、导出可携带的 .apextrace 文件，或放弃本次临时记录。" Style="{StaticResource LabelStyle}" TextWrapping="Wrap" Margin="0,0,0,22"/>
            <Border Background="#07121E" CornerRadius="8" Padding="18" Margin="0,0,0,24">
                <UniformGrid Columns="3">
                    <StackPanel><TextBlock Text="完整圈" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding CompleteLapCount}" Style="{StaticResource MetricStyle}"/></StackPanel>
                    <StackPanel><TextBlock Text="样本" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SampleCount}" Style="{StaticResource MetricStyle}"/></StackPanel>
                    <StackPanel><TextBlock Text="时长" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding DurationText}" FontSize="23" FontWeight="SemiBold"/></StackPanel>
                </UniformGrid>
            </Border>
            <TextBlock Text="会话名称将使用赛道与记录时间自动生成。" Style="{StaticResource LabelStyle}" Margin="0,0,0,22"/>
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="10"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Button Content="放弃记录" Click="Discard_Click" Style="{StaticResource DangerButtonStyle}"/>
                <Button Grid.Column="2" Content="导出文件" Command="{Binding ExportDefaultCommand}" Style="{StaticResource BaseButtonStyle}"/>
                <Button Grid.Column="4" Content="保存到记录库" Command="{Binding SaveSessionCommand}" Style="{StaticResource PrimaryButtonStyle}"/>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
