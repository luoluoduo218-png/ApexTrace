<UserControl x:Class="ApexTrace.App.Pages.HomePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="164"/><RowDefinition Height="*"/><RowDefinition Height="104"/></Grid.RowDefinitions>
        <Grid Grid.Row="0" Margin="0,0,0,12"><TextBlock Text="连接与记录就绪" Style="{StaticResource PageTitleStyle}"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="▶  开始记录" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding StartRecordingCommand}" Margin="0,0,10,0"/><Button Content="{Binding RecoverableSessionCount, StringFormat=↻  恢复临时记录 ({0})}" Style="{StaticResource BaseButtonStyle}" Command="{Binding RecoverLatestCommand}" Margin="0,0,10,0" Focusable="False"/><Button Content="▣  导入最新 LMU 遥测" Style="{StaticResource BaseButtonStyle}" Command="{Binding ImportLatestCommand}"/></StackPanel></Grid>
        <UniformGrid Grid.Row="1" Columns="7" Margin="0,0,0,14">
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="游戏状态" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding ConnectionText}" Foreground="{StaticResource SuccessGreenBrush}" FontSize="17" FontWeight="SemiBold" Margin="0,18,0,12" TextWrapping="Wrap"/><TextBlock Text="只读检测" Style="{StaticResource LabelStyle}"/></StackPanel></Border>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="采集服务" Style="{StaticResource LabelStyle}"/><TextBlock Text="官方接口" Foreground="{StaticResource SuccessGreenBrush}" FontSize="18" Margin="0,18,0,12"/><TextBlock Text="无注入 / 无 DLL" Style="{StaticResource LabelStyle}"/></StackPanel></Border>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="当前赛道" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding TrackName}" FontSize="16" Margin="0,18,0,10" TextWrapping="Wrap"/><TextBlock Text="{Binding TrackQualityText}" Foreground="{StaticResource WarningAmberBrush}"/></StackPanel></Border>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="当前赛车" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding VehicleName}" FontSize="15" Margin="0,18,0,10" TextWrapping="Wrap"/><TextBlock Text="{Binding SessionType}" Foreground="{StaticResource BlueHighlightBrush}"/></StackPanel></Border>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="数据源" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding DataSourceText}" Foreground="{StaticResource SuccessGreenBrush}" FontSize="15" Margin="0,18,0,10" TextWrapping="Wrap"/><TextBlock Text="实际文件" Style="{StaticResource LabelStyle}"/></StackPanel></Border>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="最近导入" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding DurationText}" FontSize="19" Margin="0,18,0,10"/><TextBlock Text="{Binding SampleCount, StringFormat={}{0:N0} 样本}" Style="{StaticResource LabelStyle}"/></StackPanel></Border>
            <Border Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="完整圈" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding CompleteLapCount}" Foreground="{StaticResource WarningAmberBrush}" FontSize="30" Margin="0,14,0,8"/><TextBlock Text="不足时不生成建议" Style="{StaticResource LabelStyle}" TextWrapping="Wrap"/></StackPanel></Border>
        </UniformGrid>
        <Grid Grid.Row="2" Margin="0,0,0,14"><Grid.ColumnDefinitions><ColumnDefinition Width="1.45*"/><ColumnDefinition Width="0.9*"/><ColumnDefinition Width="1.1*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,10,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="赛道预览 · 实际 LMU GPS 轨迹" FontSize="16" FontWeight="SemiBold"/><r:TrackCanvasControl Grid.Row="1" TrackPoints="{Binding TrackPoints}" CurrentProgress="{Binding ReplayProgress}" Margin="0,12,0,0"/></Grid></Border>
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="车辆与会话" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="GT" Foreground="{StaticResource BlueHighlightBrush}" FontSize="72" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,25"/><TextBlock Text="车辆" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding VehicleName}" FontSize="16" TextWrapping="Wrap" Margin="0,4,0,14"/><TextBlock Text="来源" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding DataSourceText}" Margin="0,4,0,14"/><TextBlock Text="禁止写回游戏" Foreground="{StaticResource SuccessGreenBrush}"/></StackPanel></Border>
            <StackPanel Grid.Column="2"><Border Style="{StaticResource CardStyle}" Margin="0,0,0,10"><StackPanel><TextBlock Text="开始记录指南" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10"/><TextBlock Text="1   启动 LMU" Margin="0,8"/><TextBlock Text="2   进入赛道并拥有车辆" Margin="0,8"/><TextBlock Text="3   Enable Plugins 并等待 LMU_Data" Margin="0,8"/><TextBlock Text="4   点击开始记录" Foreground="{StaticResource BlueHighlightBrush}" Margin="0,8"/></StackPanel></Border><Border Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="当前诊断" FontWeight="SemiBold"/><TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,10,0,0"/></StackPanel></Border></StackPanel>
        </Grid>
        <Border Grid.Row="3" Style="{StaticResource CardStyle}"><UniformGrid Columns="5"><StackPanel><TextBlock Text="采样基准" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SamplingRateText}" FontSize="20"/></StackPanel><StackPanel><TextBlock Text="回放刷新" Style="{StaticResource LabelStyle}"/><TextBlock Text="60 FPS" FontSize="20"/></StackPanel><StackPanel><TextBlock Text="记录样本" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SampleCount, StringFormat={}{0:N0}}" FontSize="20"/></StackPanel><StackPanel><TextBlock Text="Header" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding HeaderHashShort}" FontSize="15"/></StackPanel><StackPanel><TextBlock Text="轨迹来源" Style="{StaticResource LabelStyle}"/><TextBlock Text="运行时重建" FontSize="18" Foreground="{StaticResource WarningAmberBrush}"/></StackPanel></UniformGrid></Border>
    </Grid>
</UserControl>
