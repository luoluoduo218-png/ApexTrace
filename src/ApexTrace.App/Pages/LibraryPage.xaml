<UserControl x:Class="ApexTrace.App.Pages.LibraryPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="56"/><RowDefinition Height="58"/><RowDefinition Height="*"/></Grid.RowDefinitions>

        <Grid>
            <StackPanel Orientation="Horizontal"><TextBlock Text="记录库" Style="{StaticResource PageTitleStyle}"/><TextBlock Text="本地已保存会话" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="18,0,0,16"/></StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                <Grid Width="300" Height="38">
                    <TextBox Text="{Binding LibrarySearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource DarkTextBoxStyle}"/>
                    <TextBlock Text="⌕  搜索会话、赛道或车辆…" Foreground="#667587" Margin="12,0" VerticalAlignment="Center" IsHitTestVisible="False"><TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding LibrarySearchText}" Value=""><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style></TextBlock>
                </Grid>
                <TextBlock Text="{Binding FilteredStoredSessionCountText}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="14,0"/>
                <Button Content="▣  打开记录目录" Command="{Binding OpenStorageFolderCommand}" Style="{StaticResource BaseButtonStyle}" Padding="13,8"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="#091522" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="赛道" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="4,0,7,0"/>
                <ComboBox ItemsSource="{Binding LibraryTrackFilters}" SelectedItem="{Binding SelectedLibraryTrackFilter, Mode=TwoWay}" Style="{StaticResource DarkComboBoxStyle}" Width="130"/>
                <TextBlock Text="车辆" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="14,0,7,0"/>
                <ComboBox ItemsSource="{Binding LibraryVehicleFilters}" SelectedItem="{Binding SelectedLibraryVehicleFilter, Mode=TwoWay}" Style="{StaticResource DarkComboBoxStyle}" Width="130"/>
                <TextBlock Text="时间范围" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="14,0,7,0"/>
                <ComboBox ItemsSource="{Binding LibraryTimeFilters}" SelectedItem="{Binding SelectedLibraryTimeFilter, Mode=TwoWay}" Style="{StaticResource DarkComboBoxStyle}" Width="120"/>
                <TextBlock Text="会话" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="14,0,7,0"/>
                <ComboBox ItemsSource="{Binding LibrarySessionFilters}" SelectedItem="{Binding SelectedLibrarySessionFilter, Mode=TwoWay}" Style="{StaticResource DarkComboBoxStyle}" Width="120"/>
                <TextBlock Text="有效圈" Style="{StaticResource LabelStyle}" VerticalAlignment="Center" Margin="14,0,7,0"/>
                <ComboBox ItemsSource="{Binding LibraryValidityFilters}" SelectedItem="{Binding SelectedLibraryValidityFilter, Mode=TwoWay}" Style="{StaticResource DarkComboBoxStyle}" Width="115"/>
                <Button Content="↻  重置" Command="{Binding ResetLibraryFiltersCommand}" Style="{StaticResource BaseButtonStyle}" Padding="12,8" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="1.62*"/><ColumnDefinition Width="0.78*"/></Grid.ColumnDefinitions>
            <ListBox ItemsSource="{Binding FilteredStoredSessions}" SelectedItem="{Binding SelectedStoredSession, Mode=TwoWay}" Background="Transparent" BorderThickness="0"
                     ItemContainerStyle="{StaticResource LibrarySessionItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Height="72">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="1.45*"/><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="0.85*"/><ColumnDefinition Width="0.65*"/><ColumnDefinition Width="0.65*"/></Grid.ColumnDefinitions>
                            <Border Background="#06111C" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" ClipToBounds="True" Margin="0,0,12,0"><r:TrackCanvasControl TrackPoints="{Binding TrackPoints}" IsHitTestVisible="False" Margin="3"/></Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center"><TextBlock Text="{Binding Metadata.StartedAtUtc, StringFormat=yyyy-MM-dd  HH:mm}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/><TextBlock Text="{Binding Metadata.TrackName}" FontSize="15" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding Metadata.SessionType}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/></StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center"><TextBlock Text="车辆" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding Metadata.VehicleName}" TextTrimming="CharacterEllipsis" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Column="3" VerticalAlignment="Center"><TextBlock Text="最佳单圈" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding BestLapTimeText}" Foreground="#C66BFF" FontSize="16" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Column="4" VerticalAlignment="Center"><TextBlock Text="总 / 有效" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding LapCountText}" FontSize="15" Margin="0,5,0,0"/></StackPanel>
                            <StackPanel Grid.Column="5" VerticalAlignment="Center"><TextBlock Text="天气" Style="{StaticResource LabelStyle}"/><StackPanel Orientation="Horizontal" Margin="0,5,0,0"><TextBlock Text="☁" FontSize="16" Margin="0,0,7,0"/><TextBlock Text="{Binding TemperatureText}"/></StackPanel></StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="12,0,0,0" Padding="12">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="245"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid><TextBlock Text="{Binding SelectedStoredSession.Metadata.TrackName, StringFormat={}{0} 分析}" FontSize="17" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><TextBlock Text="•••" HorizontalAlignment="Right" Foreground="{StaticResource TextSecondaryBrush}"/></Grid>
                    <Border Grid.Row="1" Background="#06111C" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Margin="0,12,0,10" ClipToBounds="True"><r:TrackCanvasControl TrackPoints="{Binding SelectedStoredSession.TrackPoints}" Margin="8"/></Border>
                    <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                        <StackPanel><TextBlock Text="日期" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SelectedStoredSession.Metadata.StartedAtUtc, StringFormat=yyyy-MM-dd HH:mm}" Margin="0,4,0,0"/></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="车辆" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SelectedStoredSession.Metadata.VehicleName}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/></StackPanel>
                        <StackPanel Grid.Row="1"><TextBlock Text="赛道 / 长度" Style="{StaticResource LabelStyle}"/><TextBlock Margin="0,4,0,0"><Run Text="{Binding SelectedStoredSession.Metadata.TrackName, Mode=OneWay}"/><Run Text="  ·  "/><Run Text="{Binding SelectedStoredSession.TrackLengthText, Mode=OneWay}"/></TextBlock></StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1"><TextBlock Text="完整 / 有效圈" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SelectedStoredSession.LapCountText}" Margin="0,4,0,0"/></StackPanel>
                        <StackPanel Grid.Row="2"><TextBlock Text="最佳单圈" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SelectedStoredSession.BestLapTimeText}" Foreground="#C66BFF" Margin="0,4,0,0"/></StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1"><TextBlock Text="总时长 / 文件" Style="{StaticResource LabelStyle}"/><TextBlock Margin="0,4,0,0"><Run Text="{Binding SelectedStoredSession.DurationText, Mode=OneWay}"/><Run Text="  ·  "/><Run Text="{Binding SelectedStoredSession.FileSizeText, Mode=OneWay}"/></TextBlock></StackPanel>
                    </Grid>
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0"><Button Content="⌁  打开分析" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding OpenSelectedSessionCommand}" Padding="14,10"/><Button Content="⇧  导出" Style="{StaticResource BaseButtonStyle}" Command="{Binding ExportSelectedSessionCommand}" Margin="8,0,0,0" Padding="14,10"/><Button Content="▣  删除" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteSelectedSessionCommand}" Margin="8,0,0,0" Padding="14,10"/></StackPanel>
                    <TextBlock Grid.Row="4" Text="{Binding SelectedStoredSession.Path, StringFormat=文件路径  {0}}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" TextTrimming="CharacterEllipsis" Margin="0,12,0,0" ToolTip="{Binding SelectedStoredSession.Path}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
