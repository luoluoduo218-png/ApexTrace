<UserControl x:Class="ApexTrace.App.Pages.LibraryPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering" xmlns:local="clr-namespace:ApexTrace.App">
    <Grid><Grid.RowDefinitions><RowDefinition Height="62"/><RowDefinition Height="*"/></Grid.RowDefinitions><Grid><StackPanel Orientation="Horizontal"><TextBlock Text="记录库" Style="{StaticResource PageTitleStyle}"/><TextBlock Text="本地已保存会话" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="18,0,0,16"/></StackPanel><TextBox Width="330" Height="40" HorizontalAlignment="Right" VerticalContentAlignment="Center" Padding="12" Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource BorderBrush}" Text="搜索会话、赛道或标签…"/></Grid>
        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="1.55*"/><ColumnDefinition Width="0.85*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border Style="{StaticResource CardStyle}" Grid.ColumnSpan="2" Margin="0,0,0,12"><StackPanel Orientation="Horizontal"><TextBlock Text="赛道  全部赛道" Margin="0,0,28,0"/><TextBlock Text="车辆  全部车辆" Margin="0,0,28,0"/><TextBlock Text="时间范围  全部时间" Margin="0,0,28,0"/><TextBlock Text="有效圈  全部"/></StackPanel></Border>
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="138"/><RowDefinition Height="*"/></Grid.RowDefinitions><Border Background="#102034" BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="2" CornerRadius="6" Padding="14"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="140"/><ColumnDefinition Width="*"/><ColumnDefinition Width="170"/><ColumnDefinition Width="130"/></Grid.ColumnDefinitions><Border Background="#07111D" CornerRadius="5"><r:TrackCanvasControl TrackPoints="{Binding TrackPoints}"/></Border><StackPanel Grid.Column="1" Margin="18,0"><TextBlock Text="{Binding CurrentSession.Metadata.StartedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding TrackName}" FontSize="19" Margin="0,6"/><TextBlock Text="{Binding VehicleName}" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"/></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="片段时长" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding DurationText}" Foreground="#C46CFF" FontSize="22" Margin="0,8"/><TextBlock Text="{Binding SampleCount, StringFormat={}{0:N0} 样本}"/></StackPanel><StackPanel Grid.Column="3"><TextBlock Text="完整圈" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding CompleteLapCount}" FontSize="25" Margin="0,8"/><TextBlock Text="真实导入" Foreground="{StaticResource BlueHighlightBrush}"/></StackPanel></Grid></Border><DataGrid Grid.Row="1" ItemsSource="{Binding SessionLibrary}" Margin="0,12,0,0"><DataGrid.Columns><DataGridTextColumn Header="日期" Binding="{Binding StartedAtUtc, StringFormat=yyyy-MM-dd HH:mm}" Width="*"/><DataGridTextColumn Header="赛道" Binding="{Binding TrackName}" Width="1.4*"/><DataGridTextColumn Header="车辆" Binding="{Binding VehicleName}" Width="1.4*"/><DataGridTextColumn Header="类型" Binding="{Binding SessionType}" Width="*"/><DataGridCheckBoxColumn Header="完整" Binding="{Binding IsComplete}" Width="0.6*"/></DataGrid.Columns></DataGrid></Grid></Border>
            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="会话详情" FontSize="18" FontWeight="SemiBold"/><r:TrackCanvasControl TrackPoints="{Binding TrackPoints}" Height="260" Margin="0,16"/><UniformGrid Columns="2"><StackPanel Margin="0,5"><TextBlock Text="赛道" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding TrackName}"/></StackPanel><StackPanel Margin="0,5"><TextBlock Text="车辆" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding VehicleName}" TextTrimming="CharacterEllipsis"/></StackPanel><StackPanel Margin="0,5"><TextBlock Text="总样本" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SampleCount, StringFormat={}{0:N0}}"/></StackPanel><StackPanel Margin="0,5"><TextBlock Text="时长" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding DurationText}"/></StackPanel></UniformGrid><StackPanel Orientation="Horizontal" Margin="0,22,0,0"><Button Content="打开分析" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding NavigateCommand}" CommandParameter="{x:Static local:PageKind.Replay}"/><Button Content="导出" Style="{StaticResource BaseButtonStyle}" Command="{Binding ExportDefaultCommand}" Margin="10,0,0,0"/></StackPanel><TextBlock Text="{Binding CurrentSession.Metadata.SourcePath}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,18,0,0"/></StackPanel></Border>
        </Grid>
    </Grid>
</UserControl>
