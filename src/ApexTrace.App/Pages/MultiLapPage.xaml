<UserControl x:Class="ApexTrace.App.Pages.MultiLapPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <UserControl.Resources>
        <Style x:Key="OverviewMetricCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>
        <Style x:Key="ConditionChipStyle" TargetType="Border">
            <Setter Property="Background" Value="#091522" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="11,7" />
            <Setter Property="Margin" Value="6,0,0,0" />
        </Style>
        <Style x:Key="OverviewTagStyle" TargetType="Border">
            <Setter Property="Background" Value="#0D1B2A" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
        </Style>
        <Style TargetType="DataGridRow" x:Key="MultiLapDataGridRowStyle">
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="#081522" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#1C2B3B" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="RowBorder" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <DataGridCellsPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="AlternationIndex" Value="1"><Setter TargetName="RowBorder" Property="Background" Value="#0A1826" /></Trigger>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="RowBorder" Property="Background" Value="#10253D" /></Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowBorder" Property="Background" Value="#123D70" />
                                <Setter TargetName="RowBorder" Property="BorderBrush" Value="{StaticResource PrimaryBlueBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MultiLapCellTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="MultiLapDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                    <Setter Property="BorderThickness" Value="0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock Text="多圈总览" FontSize="25" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="圈速、有效性与车辆工况总览" Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" Margin="16,9,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Border Style="{StaticResource ConditionChipStyle}" MinWidth="128">
                    <StackPanel>
                        <TextBlock Text="当前轮胎" Style="{StaticResource LabelStyle}" FontSize="10" />
                        <TextBlock Text="{Binding CurrentTireText}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ConditionChipStyle}" MinWidth="82">
                    <StackPanel>
                        <TextBlock Text="燃油" Style="{StaticResource LabelStyle}" FontSize="10" />
                        <TextBlock Text="{Binding FuelText}" FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ConditionChipStyle}" MinWidth="94">
                    <StackPanel>
                        <TextBlock Text="天气" Style="{StaticResource LabelStyle}" FontSize="10" />
                        <TextBlock Text="{Binding CurrentWeatherText}" FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ConditionChipStyle}" MinWidth="84">
                    <StackPanel>
                        <TextBlock Text="气温" Style="{StaticResource LabelStyle}" FontSize="10" />
                        <TextBlock Text="{Binding AmbientText}" FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource ConditionChipStyle}" MinWidth="84">
                    <StackPanel>
                        <TextBlock Text="赛道温度" Style="{StaticResource LabelStyle}" FontSize="10" />
                        <TextBlock Text="{Binding TrackTemperatureText}" FontSize="12" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.96*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="1.18*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="58" />
                    </Grid.RowDefinitions>
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="多圈轨迹叠加" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="点击右侧圈号可高亮对应走线" Style="{StaticResource LabelStyle}" FontSize="10" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="24" Height="3" Fill="#4E9DFF" RadiusX="2" Margin="0,0,6,0" />
                            <TextBlock Text="选中圈" Style="{StaticResource LabelStyle}" FontSize="10" Margin="0,0,14,0" />
                            <Rectangle Width="24" Height="3" Fill="#32B7FF" RadiusX="2" Margin="0,0,6,0" />
                            <TextBlock Text="最快圈" Style="{StaticResource LabelStyle}" FontSize="10" Margin="0,0,14,0" />
                            <Rectangle Width="24" Height="2" Fill="#7B8796" RadiusX="2" Margin="0,0,6,0" />
                            <TextBlock Text="无效圈" Style="{StaticResource LabelStyle}" FontSize="10" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Background="#07111D" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1">
                        <r:TrackCanvasControl TrackPoints="{Binding TrackPoints}"
                                              LapTraces="{Binding MultiLapTraces}"
                                              SelectedLapNumber="{Binding SelectedMultiLapNumber}"
                                              CurrentProgress="{Binding ReplayProgress}" />
                    </Border>

                    <Grid Grid.Row="2" Margin="16,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="●" Foreground="{StaticResource PrimaryBlueBrush}" FontSize="11" Margin="0,0,7,0" />
                            <TextBlock Text="有效圈实线叠加 · 无效圈灰色虚线 · 双击复位视图" Style="{StaticResource LabelStyle}" FontSize="11" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="来源  " Style="{StaticResource LabelStyle}" FontSize="11" />
                            <TextBlock Text="{Binding TrackQualityText}" Foreground="{StaticResource BlueHighlightBrush}" FontWeight="SemiBold" FontSize="11" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="102" />
                    <RowDefinition Height="126" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource OverviewMetricCardStyle}" Margin="0,0,8,8">
                        <StackPanel><TextBlock Text="最快圈" Style="{StaticResource LabelStyle}" FontSize="11" />
                            <TextBlock Text="{Binding BestLapTimeText}" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource OverviewMetricCardStyle}" Margin="0,0,8,8">
                        <StackPanel><TextBlock Text="平均圈速" Style="{StaticResource LabelStyle}" FontSize="11" />
                            <TextBlock Text="{Binding AverageLapTimeText}" FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource OverviewMetricCardStyle}" Margin="0,0,8,8">
                        <StackPanel><TextBlock Text="理论最佳" Style="{StaticResource LabelStyle}" FontSize="11" />
                            <TextBlock Text="{Binding TheoreticalBestLapText}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource SuccessGreenBrush}" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Style="{StaticResource OverviewMetricCardStyle}" Margin="0,0,0,8">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="有效 / 总圈" Style="{StaticResource LabelStyle}" FontSize="11" />
                                <TextBlock FontSize="20" FontWeight="SemiBold" Margin="0,6,0,0">
                                    <Run Text="{Binding ValidCompleteLapCount, Mode=OneWay}" /><Run Text=" / " /><Run Text="{Binding TotalOverviewLapCount, Mode=OneWay}" />
                                </TextBlock>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding ValidLapRatioText}" Foreground="{StaticResource BlueHighlightBrush}" FontSize="11" VerticalAlignment="Bottom" Margin="6,0,0,4" />
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="14,10" Margin="0,0,0,8">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="30" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="圈速分布" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Top" />
                            <TextBlock Text="{Binding LapSpreadText}" Style="{StaticResource LabelStyle}" FontSize="10" HorizontalAlignment="Right" VerticalAlignment="Top" />
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding LapHistogramBars}" HorizontalAlignment="Stretch" VerticalAlignment="Bottom">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><UniformGrid Rows="1" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="70" ToolTip="{Binding ToolTip}" Margin="2,0">
                                        <Border Height="{Binding Height}" Background="{Binding Fill}" CornerRadius="2,2,0,0"
                                                VerticalAlignment="Bottom" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="50" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource OverviewTagStyle}" Background="#143B6D" BorderBrush="{StaticResource PrimaryBlueBrush}">
                                    <TextBlock Text="{Binding AllLapCountText}" FontSize="11" FontWeight="SemiBold" />
                                </Border>
                                <Border Style="{StaticResource OverviewTagStyle}"><TextBlock Text="{Binding ValidLapCountText}" FontSize="11" /></Border>
                                <Border Style="{StaticResource OverviewTagStyle}"><TextBlock Text="{Binding InvalidLapCountText}" FontSize="11" /></Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="S1 / S2 / S3 显示区段平均速度" Style="{StaticResource LabelStyle}" FontSize="10" VerticalAlignment="Center" />
                        </Grid>

                        <DataGrid Grid.Row="1" ItemsSource="{Binding MultiLapRows}"
                                  SelectedItem="{Binding SelectedMultiLapRow, Mode=TwoWay}"
                                  RowStyle="{StaticResource MultiLapDataGridRowStyle}"
                                  CellStyle="{StaticResource MultiLapDataGridCellStyle}"
                                  AlternationCount="2" HeadersVisibility="Column" FrozenColumnCount="2"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="圈" Binding="{Binding LapNumber}" Width="42" ElementStyle="{StaticResource MultiLapCellTextStyle}" />
                                <DataGridTextColumn Header="圈速" Binding="{Binding LapTimeText}" Width="88" ElementStyle="{StaticResource MultiLapCellTextStyle}" />
                                <DataGridTemplateColumn Header="差值" Width="62">
                                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                        <TextBlock Text="{Binding DeltaText}" Foreground="{Binding DeltaColor}" Style="{StaticResource MultiLapCellTextStyle}" />
                                    </DataTemplate></DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="S1 均速" Binding="{Binding Sector1SpeedText}" Width="76" ElementStyle="{StaticResource MultiLapCellTextStyle}" />
                                <DataGridTextColumn Header="S2 均速" Binding="{Binding Sector2SpeedText}" Width="76" ElementStyle="{StaticResource MultiLapCellTextStyle}" />
                                <DataGridTextColumn Header="S3 均速" Binding="{Binding Sector3SpeedText}" Width="76" ElementStyle="{StaticResource MultiLapCellTextStyle}" />
                                <DataGridTemplateColumn Header="有效性" Width="68">
                                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                        <TextBlock Text="{Binding ValidityText}" Foreground="{Binding ValidityColor}" Style="{StaticResource MultiLapCellTextStyle}" FontWeight="SemiBold" />
                                    </DataTemplate></DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="轮胎" Binding="{Binding TireText}" Width="92" ElementStyle="{StaticResource MultiLapCellTextStyle}" />
                                <DataGridTextColumn Header="燃油" Binding="{Binding FuelText}" Width="62" ElementStyle="{StaticResource MultiLapCellTextStyle}" />
                                <DataGridTextColumn Header="天气" Binding="{Binding WeatherText}" Width="70" ElementStyle="{StaticResource MultiLapCellTextStyle}" />
                                <DataGridTemplateColumn Header="气/轨温" Width="86">
                                    <DataGridTemplateColumn.CellTemplate><DataTemplate>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AirTemperatureText}" FontSize="11" />
                                            <TextBlock Text=" / " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                                            <TextBlock Text="{Binding TrackTemperatureText}" FontSize="11" />
                                        </StackPanel>
                                    </DataTemplate></DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
