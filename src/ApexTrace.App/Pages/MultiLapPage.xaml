<UserControl x:Class="ApexTrace.App.Pages.MultiLapPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="多圈总览" Style="{StaticResource PageTitleStyle}"/>
        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="1.15*"/><ColumnDefinition Width="1.2*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="72"/></Grid.RowDefinitions>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="真实轨迹叠加 · 当前仅一段非完整圈" FontWeight="SemiBold"/><r:TrackCanvasControl Grid.Row="1" TrackPoints="{Binding TrackPoints}" CurrentProgress="{Binding ReplayProgress}" Margin="0,12,0,0"/></Grid></Border>
            <Grid Grid.Column="1"><Grid.RowDefinitions><RowDefinition Height="116"/><RowDefinition Height="150"/><RowDefinition Height="*"/></Grid.RowDefinitions><UniformGrid Columns="4"><Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="完整圈" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding CompleteLapCount}" FontSize="28"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="样本" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SampleCount, StringFormat={}{0:N0}}" FontSize="24"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="片段时长" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding DurationText}" FontSize="20"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,0,8"><StackPanel><TextBlock Text="精度等级" Style="{StaticResource LabelStyle}"/><TextBlock Text="片段" Foreground="{StaticResource WarningAmberBrush}" FontSize="24"/></StackPanel></Border></UniformGrid>
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,8"><StackPanel><TextBlock Text="圈速分布" FontWeight="SemiBold"/><TextBlock Text="需要至少 1 个完整圈才能绘制圈速直方图" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,18,0,10"/><ProgressBar Value="0" Maximum="1"/></StackPanel></Border>
                <DataGrid Grid.Row="2" ItemsSource="{Binding Laps}" VirtualizingPanel.IsVirtualizing="True"><DataGrid.Columns><DataGridTextColumn Header="圈号" Binding="{Binding LapNumber}" Width="*"/><DataGridTextColumn Header="圈时" Binding="{Binding LapTimeSeconds, StringFormat=F3}" Width="*"/><DataGridCheckBoxColumn Header="完整" Binding="{Binding IsComplete}" Width="*"/><DataGridCheckBoxColumn Header="有效" Binding="{Binding IsValid}" Width="*"/><DataGridTextColumn Header="样本" Binding="{Binding SampleCount}" Width="*"/></DataGrid.Columns></DataGrid>
            </Grid>
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,10,12,0"><TextBlock Text="☑ 显示目标线（数据不足：关闭）     对齐方式：赛道距离 0.5m 网格     无效圈：灰色虚线" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/></Border>
        </Grid>
    </Grid>
</UserControl>
