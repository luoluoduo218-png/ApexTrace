<UserControl x:Class="ApexTrace.App.Pages.RealtimePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <Grid><Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="*"/><RowDefinition Height="186"/></Grid.RowDefinitions>
        <Grid><TextBlock Text="实时采集" Style="{StaticResource PageTitleStyle}"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="▶  开始记录" Style="{StaticResource BaseButtonStyle}" Command="{Binding StartRecordingCommand}" Margin="0,0,10,0"/><Button Content="■  结束记录" Style="{StaticResource DangerButtonStyle}" Command="{Binding EndRecordingCommand}"/><Border Background="#5A181C" BorderBrush="{StaticResource DangerRedBrush}" BorderThickness="1" CornerRadius="6" Padding="18,8" Margin="10,0,0,0"><StackPanel><TextBlock Text="● 录制状态" Foreground="{StaticResource DangerRedBrush}" HorizontalAlignment="Center"/><TextBlock Text="{Binding DurationText}" HorizontalAlignment="Center"/></StackPanel></Border></StackPanel></Grid>
        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="1.85*"/><ColumnDefinition Width="1.2*"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,10,10"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="赛道地图  |  实际走线（蓝）" FontSize="17" FontWeight="SemiBold"/><r:TrackCanvasControl Grid.Row="1" TrackPoints="{Binding TrackPoints}" CurrentProgress="{Binding ReplayProgress}" Margin="0,10,0,0"/></Grid></Border>
            <Grid Grid.Column="1" Margin="0,0,0,10"><Grid.RowDefinitions><RowDefinition Height="1.05*"/><RowDefinition Height="0.8*"/><RowDefinition Height="0.9*"/></Grid.RowDefinitions>
                <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="0.65*"/><ColumnDefinition/></Grid.ColumnDefinitions><Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="车速" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SpeedText}" FontSize="52" FontWeight="SemiBold"/><TextBlock Text="km/h" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="挡位" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding GearText}" FontSize="58" HorizontalAlignment="Center"/></StackPanel></Border><Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,0,8"><StackPanel><TextBlock Text="发动机转速" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding RpmText}" FontSize="32" HorizontalAlignment="Center" Margin="0,20,0,2"/><TextBlock Text="RPM" Style="{StaticResource LabelStyle}" HorizontalAlignment="Center"/></StackPanel></Border></Grid>
                <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="油门" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding ThrottleText}" FontSize="26"/><ProgressBar Value="{Binding ThrottleValue}" Maximum="1" Foreground="{StaticResource SuccessGreenBrush}"/></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="刹车" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding BrakeText}" FontSize="26"/><ProgressBar Value="{Binding BrakeValue}" Maximum="1" Foreground="{StaticResource DangerRedBrush}"/></StackPanel></Border><Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="0,0,0,8"><StackPanel><TextBlock Text="方向盘角度" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SteeringText}" FontSize="26" Margin="0,8,0,0"/></StackPanel></Border></Grid>
                <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><Border Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="圈内距离" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding LapDistanceText}" FontSize="22" Margin="0,10,0,0"/></StackPanel></Border><Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,8,0"><StackPanel><TextBlock Text="环境 / 赛道" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding AmbientText}" FontSize="20" Margin="0,8,0,0"/><TextBlock Text="{Binding TrackTemperatureText}" Foreground="{StaticResource WarningAmberBrush}"/></StackPanel></Border><Border Grid.Column="2" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="燃油" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding FuelText}" FontSize="27" Margin="0,10,0,0"/></StackPanel></Border></Grid>
            </Grid>
        </Grid>
        <Border Grid.Row="2" Style="{StaticResource CardStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="52"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="圈数进度 / 原始 LMU 时间轴" FontWeight="SemiBold"/><StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10"><Border Background="#163D6C" BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="1" CornerRadius="4" Padding="18,8"><TextBlock Text="{Binding CurrentLapText, StringFormat=圈 {0}}"/></Border><TextBlock Text="{Binding ImportSummary}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="18,0"/></StackPanel><Grid Grid.Row="2"><Slider Minimum="0" Maximum="1" Value="{Binding ReplayProgress}" VerticalAlignment="Top"/><StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"><Button Content="⏯  回放" Style="{StaticResource BaseButtonStyle}" Command="{Binding ToggleReplayCommand}"/><TextBlock Text="{Binding CompletenessText}" Foreground="{StaticResource WarningAmberBrush}" TextWrapping="Wrap" Margin="18,10,0,0"/></StackPanel></Grid></Grid></Border>
    </Grid>
</UserControl>
