<UserControl x:Class="ApexTrace.App.Pages.RealtimePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering"
             xmlns:pages="clr-namespace:ApexTrace.App.Pages"
             Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="56" /><RowDefinition Height="*" /><RowDefinition Height="188" /></Grid.RowDefinitions>

        <Grid>
            <TextBlock Text="实时采集" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="▷  开始记录" Style="{StaticResource BaseButtonStyle}" Command="{Binding StartRecordingCommand}" Width="176" Margin="0,0,10,0" ToolTip="连接 LMU 并进入赛道后开始只读采集" />
                <Button Content="■  结束记录" Style="{StaticResource DangerButtonStyle}" Command="{Binding EndRecordingCommand}" Width="176" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,8,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TrackPanelColumn" Width="1.62*" MinWidth="360" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition x:Name="DataPanelColumn" Width="1.38*" MinWidth="360" />
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
                <Grid>
                    <r:TrackCanvasControl x:Name="RealtimeTrack" TrackPoints="{Binding RealtimeTrackPoints}" ReferencePoints="{Binding ComparisonReferencePoints}" ReferenceColor="#20C76F" CurrentProgress="{Binding RealtimeTrackProgress}" />
                    <ToggleButton Style="{StaticResource CollapsibleMapLegendStyle}" HorizontalAlignment="Left"
                                  VerticalAlignment="Top" Margin="14" ToolTip="点击收起或显示赛道图例">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"><TextBlock Text="赛道地图  |  " FontSize="16" FontWeight="SemiBold" /><TextBlock Text="{Binding TrackName, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" /></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0"><Border Width="34" Height="5" CornerRadius="3" Background="{StaticResource PrimaryBlueBrush}" Margin="0,6,10,0" /><TextBlock Text="当前圈轨迹" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,7,0,0"><Border Width="34" Height="5" CornerRadius="3" Background="{StaticResource SuccessGreenBrush}" Margin="0,6,10,0" /><TextBlock Text="参考轨迹（最佳圈）" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,7,0,0"><Ellipse Width="9" Height="9" Fill="White" Margin="12,4,23,0" /><TextBlock Text="当前位置" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel>
                        </StackPanel>
                    </ToggleButton>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,12">
                        <Button Content="＋" Style="{StaticResource IconButtonStyle}" Click="ZoomIn_OnClick" FontSize="23" ToolTip="放大；也可使用鼠标滚轮" />
                        <Button Content="－" Style="{StaticResource IconButtonStyle}" Click="ZoomOut_OnClick" FontSize="23" Margin="0,4,0,0" ToolTip="缩小" />
                        <Button Content="⌗" Style="{StaticResource IconButtonStyle}" Click="Fit_OnClick" FontSize="19" Margin="0,4,0,0" ToolTip="适应窗口；也可双击地图" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="18">
                        <TextBlock Text="▦" FontSize="28" Margin="0,0,10,0" /><StackPanel><TextBlock Text="{Binding TrackName}" FontWeight="SemiBold" /><TextBlock Text="滚轮缩放 · 拖动平移 · 双击复位" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" /></StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="1" Style="{StaticResource PanelGridSplitterStyle}"
                          DragCompleted="MainGridSplitter_OnDragCompleted" ToolTip="左右拖动，调整赛道图与遥测数据比例" />
            <Viewbox Grid.Column="2" Stretch="Fill"><pages:TelemetryDashboard Width="600" Height="500" /></Viewbox>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="24" /><RowDefinition Height="46" /><RowDefinition Height="36" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <TextBlock Text="圈数进度" FontSize="15" FontWeight="SemiBold" />
                <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition /></Grid.ColumnDefinitions>
                    <TextBlock Text="圈数" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding DashboardLaps}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate><Border Background="#091522" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="12,8" MinWidth="135" Margin="0,0,5,0"><StackPanel Orientation="Horizontal"><TextBlock Text="{Binding LapNumber}" FontWeight="SemiBold" Width="25" /><TextBlock Text="{Binding LapTimeSeconds, Converter={StaticResource SecondsToLapTime}}" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
                <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition /><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions>
                    <TextBlock Text="赛段" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                    <Border Grid.Column="1" BorderBrush="{StaticResource SuccessGreenBrush}" BorderThickness="0,2,0,0" Background="#081522"><StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="S1" Foreground="{StaticResource SuccessGreenBrush}" FontWeight="SemiBold" /><TextBlock Text="{Binding Sector1TimeText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0" /></StackPanel></Border>
                    <Border Grid.Column="2" BorderBrush="{StaticResource WarningAmberBrush}" BorderThickness="0,2,0,0" Background="#081522"><StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="S2" Foreground="{StaticResource WarningAmberBrush}" FontWeight="SemiBold" /><TextBlock Text="{Binding Sector2TimeText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0" /></StackPanel></Border>
                    <Border Grid.Column="3" BorderBrush="#B953E7" BorderThickness="0,2,0,0" Background="#081522"><StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"><TextBlock Text="S3" Foreground="#C760F1" FontWeight="SemiBold" /><TextBlock Text="{Binding Sector3TimeText}" Foreground="{StaticResource TextSecondaryBrush}" Margin="12,0,0,0" /></StackPanel></Border>
                </Grid>
                <Grid Grid.Row="3" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal"><Button Content="⏯" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ToggleReplayCommand}" Padding="15,10" ToolTip="播放或暂停已载入记录" /><Button Content="◀ 10s" Style="{StaticResource IconButtonStyle}" Command="{Binding SeekReplayCommand}" CommandParameter="-10" Margin="8,0,0,0" /><Button Content="10s ▶" Style="{StaticResource IconButtonStyle}" Command="{Binding SeekReplayCommand}" CommandParameter="10" Margin="4,0,0,0" /><Border Background="#091522" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="14,8" Margin="8,0,0,0"><TextBlock Text="{Binding PlaybackRateText}" Foreground="{StaticResource BlueHighlightBrush}" /></Border></StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="18,0" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"><TextBlock Text="{Binding DurationText}" Foreground="{StaticResource BlueHighlightBrush}" FontSize="17" FontWeight="SemiBold" /><TextBlock Text=" / ∞" Foreground="{StaticResource TextSecondaryBrush}" FontSize="16" /></StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
