<UserControl x:Class="ApexTrace.App.Pages.ReplayPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <Grid><Grid.RowDefinitions><RowDefinition Height="50"/><RowDefinition Height="*"/><RowDefinition Height="150"/></Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal"><Border Background="#173E70" BorderBrush="{StaticResource PrimaryBlueBrush}" BorderThickness="1" CornerRadius="5" Padding="18,9" Margin="0,0,8,0"><TextBlock Text="真实片段  ·  00:45.690"/></Border><Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="18,9"><TextBlock Text="完整圈不可用" Foreground="{StaticResource WarningAmberBrush}"/></Border></StackPanel>
        <Grid Grid.Row="1"><Grid.ColumnDefinitions><ColumnDefinition Width="1.75*"/><ColumnDefinition Width="1.1*"/></Grid.ColumnDefinitions><Border Style="{StaticResource CardStyle}" Margin="0,0,10,10"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="赛道地图  |  LMU 事件点同步回放" FontWeight="SemiBold"/><r:TrackCanvasControl Grid.Row="1" TrackPoints="{Binding TrackPoints}" CurrentProgress="{Binding ReplayProgress}" Margin="0,10,0,0"/></Grid></Border>
            <Grid Grid.Column="1" Margin="0,0,0,10"><Grid.RowDefinitions><RowDefinition Height="186"/><RowDefinition Height="*"/></Grid.RowDefinitions><UniformGrid Columns="3"><Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="车速" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding SpeedText}" FontSize="39"/><TextBlock Text="km/h" Style="{StaticResource LabelStyle}"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,8,8"><StackPanel><TextBlock Text="挡位" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding GearText}" FontSize="49" HorizontalAlignment="Center"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,0,8"><StackPanel><TextBlock Text="RPM" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding RpmText}" FontSize="27" Margin="0,16,0,0"/></StackPanel></Border></UniformGrid><Border Grid.Row="1" Style="{StaticResource CardStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="事件日志" FontWeight="SemiBold"/><DataGrid Grid.Row="1" ItemsSource="{Binding Events}" Margin="0,10,0,0"><DataGrid.Columns><DataGridTextColumn Header="时间" Binding="{Binding SessionElapsedSeconds, StringFormat=F3}" Width="*"/><DataGridTextColumn Header="事件" Binding="{Binding Type}" Width="1.3*"/><DataGridTextColumn Header="位置" Binding="{Binding LapDistanceMeters, StringFormat=F1}" Width="*"/></DataGrid.Columns></DataGrid></Grid></Border></Grid>
        </Grid>
        <Border Grid.Row="2" Style="{StaticResource CardStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="52"/><RowDefinition Height="*"/></Grid.RowDefinitions><TextBlock Text="回放控制" FontWeight="SemiBold"/><StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8"><Button Content="⏯  播放 / 暂停" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ToggleReplayCommand}"/><Button Content="◀ -1帧" Style="{StaticResource BaseButtonStyle}" Margin="10,0,0,0"/><Button Content="+1帧 ▶" Style="{StaticResource BaseButtonStyle}" Margin="10,0,0,0"/><TextBlock Text="0.25x    0.5x    1x    2x" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0"/></StackPanel><Slider Grid.Row="2" Minimum="0" Maximum="1" Value="{Binding ReplayProgress}"/></Grid></Border>
    </Grid>
</UserControl>
