<UserControl x:Class="ApexTrace.App.Pages.ReplayPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering"
             xmlns:pages="clr-namespace:ApexTrace.App.Pages"
             Loaded="OnLoaded">
    <Grid>
        <Grid.RowDefinitions><RowDefinition Height="54" /><RowDefinition Height="*" /><RowDefinition Height="132" /></Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <ListBox ItemsSource="{Binding ReplayableLaps}" SelectedItem="{Binding SelectedReplayLap, Mode=TwoWay}" Style="{StaticResource FlatListBoxStyle}" ItemContainerStyle="{StaticResource LapTabListBoxItemStyle}" ScrollViewer.HorizontalScrollBarVisibility="Hidden" Margin="0,0,8,7">
                <ListBox.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ListBox.ItemsPanel>
                <ListBox.ItemTemplate><DataTemplate><StackPanel Orientation="Horizontal"><TextBlock Text="圈" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" /><TextBlock Text="{Binding LapNumber}" FontSize="16" FontWeight="SemiBold" Margin="5,0,7,0" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" /><TextBlock Text="{Binding LapTimeSeconds, Converter={StaticResource SecondsToLapTime}}" Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}" /></StackPanel></DataTemplate></ListBox.ItemTemplate>
            </ListBox>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,7">
                <Button Content="▷  开始记录" Style="{StaticResource BaseButtonStyle}" Command="{Binding StartRecordingCommand}" Width="132" Margin="0,0,7,0" Padding="10,8" />
                <Button Content="■  结束记录" Style="{StaticResource DangerButtonStyle}" Command="{Binding EndRecordingCommand}" Width="132" Padding="10,8" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="TrackPanelColumn" Width="1.62*" MinWidth="360" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition x:Name="DataPanelColumn" Width="1.08*" MinWidth="360" />
            </Grid.ColumnDefinitions>
            <Grid Margin="0,0,0,8">
                <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="136" /></Grid.RowDefinitions>
                <Border Style="{StaticResource CardStyle}" Padding="0" Margin="0,0,0,8" ClipToBounds="True">
                    <Grid>
                        <r:TrackCanvasControl x:Name="ReplayTrack" TrackPoints="{Binding ReplayTrackPoints}" ReferencePoints="{Binding ComparisonReferencePoints}" ReferenceColor="#748191" Events="{Binding ReplayEvents}" CurrentProgress="{Binding ReplayProgress}" />
                        <ToggleButton Style="{StaticResource CollapsibleMapLegendStyle}" HorizontalAlignment="Left"
                                      VerticalAlignment="Top" Margin="13" ToolTip="点击收起或显示赛道图例">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal"><TextBlock Text="赛道地图  |  " FontSize="16" FontWeight="SemiBold" /><TextBlock Text="{Binding TrackName, Mode=OneWay}" FontSize="16" FontWeight="SemiBold" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Border Width="30" Height="5" CornerRadius="3" Background="{StaticResource PrimaryBlueBrush}" Margin="0,6,10,0" /><TextBlock Text="当前圈轨迹" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"><Border Width="30" Height="3" Background="#748191" Margin="0,7,10,0" /><TextBlock Text="参考轨迹（最佳圈）" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"><Ellipse Width="10" Height="10" Fill="{StaticResource DangerRedBrush}" Margin="10,4,20,0" /><TextBlock Text="刹车点" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"><Ellipse Width="10" Height="10" Fill="{StaticResource WarningAmberBrush}" Margin="10,4,20,0" /><TextBlock Text="弯心 / 入弯" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0"><Ellipse Width="10" Height="10" Fill="{StaticResource SuccessGreenBrush}" Margin="10,4,20,0" /><TextBlock Text="补油点" Foreground="{StaticResource TextSecondaryBrush}" /></StackPanel>
                            </StackPanel>
                        </ToggleButton>
                        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,10,10"><Button Content="＋" Style="{StaticResource IconButtonStyle}" Click="ZoomIn_OnClick" FontSize="22" /><Button Content="－" Style="{StaticResource IconButtonStyle}" Click="ZoomOut_OnClick" FontSize="22" Margin="0,4,0,0" /><Button Content="⌗" Style="{StaticResource IconButtonStyle}" Click="Fit_OnClick" FontSize="18" Margin="0,4,0,0" /></StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16"><TextBlock Text="▦" FontSize="27" Margin="0,0,9,0" /><StackPanel><TextBlock Text="{Binding TrackName}" FontWeight="SemiBold" /><TextBlock Text="地图与时间轴双向同步" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" /></StackPanel></StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="14,10">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="23" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <TextBlock Text="回放控制" FontWeight="SemiBold" />
                        <Grid Grid.Row="1" Margin="0,8,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="12" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="12" /><ColumnDefinition Width="Auto" /><ColumnDefinition /></Grid.ColumnDefinitions>
                            <Button Content="⏯" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ToggleReplayCommand}" Width="64" FontSize="21" ToolTip="播放 / 暂停（空格）" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0"><Button Content="◀ 事件" Style="{StaticResource IconButtonStyle}" Command="{Binding JumpToEventCommand}" CommandParameter="-1" /><Button Content="事件 ▶" Style="{StaticResource IconButtonStyle}" Command="{Binding JumpToEventCommand}" CommandParameter="1" Margin="4,0,0,0" /></StackPanel>
                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                <RadioButton Content="0.25x" Style="{StaticResource SegmentRadioButtonStyle}" GroupName="ReplayRate" IsChecked="{Binding PlaybackRate, Converter={StaticResource DoubleEquals}, ConverterParameter=0.25, Mode=OneWay}" Command="{Binding SetPlaybackRateCommand}" CommandParameter="0.25" Padding="13,10" />
                                <RadioButton Content="0.5x" Style="{StaticResource SegmentRadioButtonStyle}" GroupName="ReplayRate" IsChecked="{Binding PlaybackRate, Converter={StaticResource DoubleEquals}, ConverterParameter=0.5, Mode=OneWay}" Command="{Binding SetPlaybackRateCommand}" CommandParameter="0.5" Padding="13,10" />
                                <RadioButton Content="1x" Style="{StaticResource SegmentRadioButtonStyle}" GroupName="ReplayRate" IsChecked="{Binding PlaybackRate, Converter={StaticResource DoubleEquals}, ConverterParameter=1, Mode=OneWay}" Command="{Binding SetPlaybackRateCommand}" CommandParameter="1" Padding="13,10" />
                                <RadioButton Content="2x" Style="{StaticResource SegmentRadioButtonStyle}" GroupName="ReplayRate" IsChecked="{Binding PlaybackRate, Converter={StaticResource DoubleEquals}, ConverterParameter=2, Mode=OneWay}" Command="{Binding SetPlaybackRateCommand}" CommandParameter="2" Padding="13,10" />
                            </StackPanel>
                            <StackPanel Grid.Column="5" Orientation="Horizontal"><Button Content="◀ 10s" Style="{StaticResource IconButtonStyle}" Command="{Binding SeekReplayCommand}" CommandParameter="-10" /><Button Content="10s ▶" Style="{StaticResource IconButtonStyle}" Command="{Binding SeekReplayCommand}" CommandParameter="10" Margin="4,0,0,0" /></StackPanel>
                            <TextBlock Grid.Column="6" Text="{Binding ReplayAvailabilityText}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="12,0,0,0" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <GridSplitter Grid.Column="1" Style="{StaticResource PanelGridSplitterStyle}"
                          DragCompleted="MainGridSplitter_OnDragCompleted" ToolTip="左右拖动，调整赛道图与遥测数据比例" />

            <Grid Grid.Column="2" Margin="0,0,0,8">
                <Grid.RowDefinitions><RowDefinition Height="2.25*" /><RowDefinition Height="1*" /></Grid.RowDefinitions>
                <Viewbox Stretch="Fill"><pages:TelemetryDashboard Width="600" Height="500" /></Viewbox>
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="10,8" Margin="0,8,0,0">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="24" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid><TextBlock Text="事件日志" FontWeight="SemiBold" /><TextBlock Text="刹车 · 油门 · 换挡 · 车辆电子 · 圈状态" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" FontSize="11" /></Grid>
                        <DataGrid Grid.Row="1" ItemsSource="{Binding ReplayEventRows}" Margin="0,5,0,0" RowHeight="25" ColumnHeaderHeight="27" FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding TimeText}" Width="1.15*" />
                                <DataGridTemplateColumn Header="事件" Width="1.2*"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding EventText}" Foreground="{Binding Accent}" VerticalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                <DataGridTextColumn Header="位置" Binding="{Binding PositionText}" Width="0.75*" />
                                <DataGridTextColumn Header="数值" Binding="{Binding ValueText}" Width="1*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="14,9">
            <Grid><Grid.RowDefinitions><RowDefinition Height="20" /><RowDefinition Height="58" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                <Grid><TextBlock Text="事件时间轴" FontWeight="SemiBold" /><TextBlock Text="完整单圈事件 · 拖动可定位地图、仪表和事件日志" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Right" FontSize="11" /></Grid>
                <r:ReplayTimelineControl Grid.Row="1" Events="{Binding ReplayEvents}" StartSeconds="{Binding ReplayStartSeconds}" DurationSeconds="{Binding ReplayDurationSeconds}" Progress="{Binding ReplayProgress, Mode=TwoWay}" />
                <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal"><TextBlock Text="{Binding ReplayElapsedText}" Foreground="{StaticResource BlueHighlightBrush}" FontSize="16" FontWeight="SemiBold" /><TextBlock Text=" / " Foreground="{StaticResource TextSecondaryBrush}" /><TextBlock Text="{Binding ReplayTotalText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="16" /></StackPanel>
                    <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding ReplayProgress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="18,0" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Content="⌗ 适应地图" Style="{StaticResource IconButtonStyle}" Click="Fit_OnClick" Padding="12,6" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
