<UserControl x:Class="ApexTrace.App.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="230"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="设置" Style="{StaticResource PageTitleStyle}"/>
                <Border Background="#102034" CornerRadius="6" Padding="14,12" Margin="0,5"><TextBlock Text="常规"/></Border>
                <Border Padding="14,12" Margin="0,5"><TextBlock Text="游戏连接" Foreground="{StaticResource BlueHighlightBrush}"/></Border>
                <Border Padding="14,12" Margin="0,5"><TextBlock Text="数据与存储"/></Border>
                <Border Padding="14,12" Margin="0,5"><TextBlock Text="关于 ApexTrace"/></Border>
            </StackPanel>
        </Border>
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="游戏连接" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="只读使用 Le Mans Ultimate 官方 LMU_Data 共享内存与可访问遥测文件。" Style="{StaticResource LabelStyle}" Margin="0,0,0,18"/>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="190"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="连接状态" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding ConnectionText}" FontSize="18" Foreground="{StaticResource SuccessGreenBrush}" Margin="0,8,0,0"/></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="安装目录" Style="{StaticResource LabelStyle}"/><TextBlock Text="{Binding Connection.InstallationPath}" Margin="0,8,0,14"/><TextBlock Text="{Binding Connection.Diagnostic}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/></StackPanel>
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="官方遥测文件" FontSize="18" FontWeight="SemiBold"/><TextBlock Text="游戏未运行时，可导入 LMU 官方写出的 DuckDB 文件用于回放和分析。" Style="{StaticResource LabelStyle}" Margin="0,7,0,0"/></StackPanel>
                        <Button Grid.Column="1" Content="重新扫描并导入" Command="{Binding ImportLatestCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="20,0,0,0"/>
                    </Grid>
                </Border>
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel><TextBlock Text="安全边界" FontSize="18" FontWeight="SemiBold"/><TextBlock Margin="0,12,0,0" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Text="ApexTrace 不注入游戏进程、不写入共享内存、不加载旧 rFactor 2 共享内存 DLL，也不尝试解密受保护的游戏资源。赛道形状缺失时仅由合法遥测轨迹重建。"/></StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
