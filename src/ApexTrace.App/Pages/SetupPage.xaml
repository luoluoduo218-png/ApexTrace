<UserControl x:Class="ApexTrace.App.Pages.SetupPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="190"/><RowDefinition Height="*"/></Grid.RowDefinitions><Grid><StackPanel Orientation="Horizontal"><TextBlock Text="调教建议" Style="{StaticResource PageTitleStyle}"/><TextBlock Text="基于当前数据和赛道特性" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="18,0,0,16"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="⇩ 导出调教建议" Style="{StaticResource BaseButtonStyle}" IsEnabled="False" Margin="0,0,10,0"/><Button Content="✎ 应用到方案" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="False"/></StackPanel></Grid>
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,14"><Border Style="{StaticResource CardStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="主要调教结论" Foreground="{StaticResource WarningAmberBrush}" FontWeight="SemiBold"/><TextBlock Text="{Binding SetupRecommendationHeadline}" FontSize="20" Margin="0,18,0,8" TextWrapping="Wrap"/><TextBlock Text="基于重复介入信号，不自动写回" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="✓ 预测与建议" Foreground="{StaticResource SuccessGreenBrush}" FontWeight="SemiBold"/><TextBlock Text="{Binding RecommendationCountText}" FontSize="34" Margin="0,18,0,8"/><TextBlock Text="含圈速基准与调教实验" Foreground="{StaticResource TextSecondaryBrush}"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="下一圈基准" Foreground="{StaticResource BlueHighlightBrush}" FontWeight="SemiBold"/><TextBlock Text="{Binding RecommendationImpactText}" FontSize="27" Margin="0,18,0,8"/><TextBlock Text="最近完整有效圈中位数" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/></StackPanel></Border><Border Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="完整圈" Foreground="#B06CFF" FontWeight="SemiBold"/><TextBlock Text="{Binding CompleteLapCount}" FontSize="34" Margin="0,18,0,8"/><TextBlock Text="至少 3 圈生成调教建议" Foreground="{StaticResource TextSecondaryBrush}"/></StackPanel></Border></UniformGrid>
        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="1.7*"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions><Border Style="{StaticResource CardStyle}" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="LMU 可确认的当前控制值（只读）" FontSize="16" FontWeight="SemiBold"/><DataGrid Grid.Row="1" ItemsSource="{Binding SetupSnapshot.Values}" Margin="0,12"><DataGrid.Columns><DataGridTextColumn Header="项目" Binding="{Binding Key}" Width="1.7*"/><DataGridTextColumn Header="当前值" Binding="{Binding DisplayValue}" Width="*"/><DataGridTextColumn Header="数值" Binding="{Binding NumericValue}" Width="0.7*"/><DataGridCheckBoxColumn Header="可用" Binding="{Binding Available}" Width="0.5*"/></DataGrid.Columns></DataGrid><TextBlock Grid.Row="2" Text="{Binding SetupSnapshot.Diagnostic}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/></Grid></Border><Border Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="调教实验依据" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="重复现象" Foreground="{StaticResource BlueHighlightBrush}" Margin="0,18,0,10"/><Border Background="#101F2D" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14"><StackPanel><TextBlock Text="游戏遥测与完整圈" FontWeight="SemiBold"/><TextBlock Text="只读分析，不写回设置" Foreground="{StaticResource SuccessGreenBrush}" Margin="0,6,0,0"/></StackPanel></Border><Border Background="#101F2D" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,10,0,0"><StackPanel><TextBlock Text="证据" FontWeight="SemiBold"/><TextBlock Text="{Binding SetupRecommendationEvidenceText}" Foreground="{StaticResource WarningAmberBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/></StackPanel></Border><TextBlock Text="{Binding SetupRecommendationValidationText}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,22,0,0"/></StackPanel></Border></Grid>
    </Grid>
</UserControl>
