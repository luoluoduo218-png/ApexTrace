<UserControl x:Class="ApexTrace.App.Pages.SetupPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid><Grid.RowDefinitions><RowDefinition Height="58"/><RowDefinition Height="190"/><RowDefinition Height="*"/></Grid.RowDefinitions><Grid><StackPanel Orientation="Horizontal"><TextBlock Text="调教建议" Style="{StaticResource PageTitleStyle}"/><TextBlock Text="基于当前数据和赛道特性" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="18,0,0,16"/></StackPanel><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="⇩ 导出调教建议" Style="{StaticResource BaseButtonStyle}" IsEnabled="False" Margin="0,0,10,0"/><Button Content="✎ 应用到方案" Style="{StaticResource PrimaryButtonStyle}" IsEnabled="False"/></StackPanel></Grid>
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,14"><Border Style="{StaticResource CardStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="⚠ 当前主要问题" Foreground="{StaticResource WarningAmberBrush}" FontWeight="SemiBold"/><TextBlock Text="数据不足" FontSize="28" Margin="0,18,0,8"/><TextBlock Text="需要至少 3 个相近条件下的完整有效圈" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="✓ 推荐改动" Foreground="{StaticResource SuccessGreenBrush}" FontWeight="SemiBold"/><TextBlock Text="0 项" FontSize="34" Margin="0,18,0,8"/><TextBlock Text="不会根据片段猜测" Foreground="{StaticResource TextSecondaryBrush}"/></StackPanel></Border><Border Style="{StaticResource CardStyle}" Margin="0,0,10,0"><StackPanel><TextBlock Text="预计影响" Foreground="{StaticResource BlueHighlightBrush}" FontWeight="SemiBold"/><TextBlock Text="--" FontSize="34" Margin="0,18,0,8"/><TextBlock Text="没有证据时不估算收益" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/></StackPanel></Border><Border Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="适用赛段" Foreground="#B06CFF" FontWeight="SemiBold"/><TextBlock Text="等待完整圈" FontSize="23" Margin="0,18,0,8"/><TextBlock Text="目标线未生成" Foreground="{StaticResource TextSecondaryBrush}"/></StackPanel></Border></UniformGrid>
        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="1.7*"/><ColumnDefinition Width="0.9*"/></Grid.ColumnDefinitions><Border Style="{StaticResource CardStyle}" Margin="0,0,12,0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Text="官方 LMU 调教快照（只读）" FontSize="16" FontWeight="SemiBold"/><DataGrid Grid.Row="1" ItemsSource="{Binding SetupSnapshot.Values}" Margin="0,12"><DataGrid.Columns><DataGridTextColumn Header="键" Binding="{Binding Key}" Width="1.7*"/><DataGridTextColumn Header="当前值" Binding="{Binding DisplayValue}" Width="*"/><DataGridTextColumn Header="数值" Binding="{Binding NumericValue}" Width="0.7*"/><DataGridCheckBoxColumn Header="可用" Binding="{Binding Available}" Width="0.5*"/></DataGrid.Columns></DataGrid><TextBlock Grid.Row="2" Text="{Binding SetupSnapshot.Diagnostic}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/></Grid></Border><Border Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="数据依据" FontSize="16" FontWeight="SemiBold"/><TextBlock Text="关键现象" Foreground="{StaticResource BlueHighlightBrush}" Margin="0,18,0,10"/><Border Background="#101F2D" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14"><StackPanel><TextBlock Text="LMU 原生调教元数据" FontWeight="SemiBold"/><TextBlock Text="已读取但不写回" Foreground="{StaticResource SuccessGreenBrush}" Margin="0,6,0,0"/></StackPanel></Border><Border Background="#101F2D" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,10,0,0"><StackPanel><TextBlock Text="驾驶证据" FontWeight="SemiBold"/><TextBlock Text="无完整圈，建议被抑制" Foreground="{StaticResource WarningAmberBrush}" Margin="0,6,0,0"/></StackPanel></Border><TextBlock Text="所有未来建议都会包含证据、置信度、副作用和验证方法。" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" Margin="0,22,0,0"/></StackPanel></Border></Grid>
    </Grid>
</UserControl>
