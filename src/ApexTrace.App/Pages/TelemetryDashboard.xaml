<UserControl x:Class="ApexTrace.App.Pages.TelemetryDashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:r="clr-namespace:ApexTrace.Rendering;assembly=ApexTrace.Rendering">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1.15*" />
            <RowDefinition Height="0.72*" />
            <RowDefinition Height="0.72*" />
            <RowDefinition Height="1.35*" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.62*" /><ColumnDefinition Width="0.88*" />
                <ColumnDefinition Width="0.58*" /><ColumnDefinition Width="1.07*" />
            </Grid.ColumnDefinitions>
            <Border Style="{StaticResource TelemetryCardStyle}" Margin="0,0,6,6">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <TextBlock Text="方向盘" Style="{StaticResource TelemetryLabelStyle}" HorizontalAlignment="Center" />
                    <r:SteeringIndicatorControl Grid.Row="1" Value="{Binding SteeringDegrees}" Width="64" Height="64" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <TextBlock Grid.Row="2" Text="{Binding SteeringText}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource BlueHighlightBrush}" HorizontalAlignment="Center" />
                </Grid>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource TelemetryCardStyle}" Margin="0,0,6,6">
                <Grid><TextBlock Text="车速" Style="{StaticResource TelemetryLabelStyle}" VerticalAlignment="Top" />
                    <r:TelemetryGaugeControl Value="{Binding SpeedValue}" Maximum="400" DisplayText="{Binding SpeedText}" Unit="km/h" Margin="-6,11,-6,-4" />
                </Grid>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource TelemetryCardStyle}" Margin="0,0,6,6">
                <Grid><TextBlock Text="挡位" Style="{StaticResource TelemetryLabelStyle}" VerticalAlignment="Top" />
                    <TextBlock Text="{Binding GearText}" FontSize="50" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0" />
                </Grid>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource TelemetryCardStyle}" Margin="0,0,0,6">
                <Grid><TextBlock Text="发动机转速" Style="{StaticResource TelemetryLabelStyle}" VerticalAlignment="Top" />
                    <r:TelemetryGaugeControl Value="{Binding RpmValue}" Maximum="10000" DisplayText="{Binding RpmText}" Unit="RPM" ShowRedZone="True" Margin="-6,10,-6,-4" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Visibility="{Binding IsClassicPedalDisplay, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions>
            <Border Style="{StaticResource TelemetryCardStyle}" Margin="0,0,6,6">
                <Grid><Grid.RowDefinitions><RowDefinition /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="油门" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding ThrottleText}" Style="{StaticResource TelemetryValueStyle}" /></StackPanel>
                    <ProgressBar Grid.Row="1" Value="{Binding ThrottleValue}" Maximum="1" Foreground="{StaticResource SuccessGreenBrush}" />
                </Grid>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource TelemetryCardStyle}" Margin="0,0,6,6">
                <Grid><Grid.RowDefinitions><RowDefinition /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="刹车" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding BrakeText}" Style="{StaticResource TelemetryValueStyle}" /></StackPanel>
                    <ProgressBar Grid.Row="1" Value="{Binding BrakeValue}" Maximum="1" Foreground="{StaticResource DangerRedBrush}" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Visibility="{Binding IsClassicPedalDisplay, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*" /><ColumnDefinition Width="1*" /><ColumnDefinition Width="1.05*" /><ColumnDefinition Width="1.05*" /></Grid.ColumnDefinitions>
            <Border Style="{StaticResource TelemetryCardStyle}" Margin="0,0,6,6"><StackPanel><TextBlock Text="单圈时间" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding LapTimeText}" FontSize="22" Margin="0,7,0,0" /></StackPanel></Border>
            <Border Grid.Column="1" Style="{StaticResource TelemetryCardStyle}" Margin="0,0,6,6"><StackPanel><TextBlock Text="与最佳圈差" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding BestDeltaText}" FontSize="24" Foreground="{StaticResource SuccessGreenBrush}" Margin="0,6,0,0" /></StackPanel></Border>
            <Border Grid.Column="2" Style="{StaticResource TelemetryCardStyle}" Margin="0,0,6,6"><Grid><StackPanel><TextBlock Text="横向 G" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding LateralGText}" FontSize="17" Margin="0,9,0,0" /></StackPanel><r:GForceIndicatorControl Value="{Binding LateralGValue}" Width="56" Height="56" HorizontalAlignment="Right" VerticalAlignment="Center" /></Grid></Border>
            <Border Grid.Column="3" Style="{StaticResource TelemetryCardStyle}" Margin="0,0,0,6"><Grid><StackPanel><TextBlock Text="纵向 G" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding LongitudinalGText}" FontSize="17" Margin="0,9,0,0" /></StackPanel><r:GForceIndicatorControl Value="{Binding LongitudinalGValue}" Horizontal="False" Width="56" Height="56" HorizontalAlignment="Right" VerticalAlignment="Center" /></Grid></Border>
        </Grid>

        <Grid Grid.Row="1" Grid.RowSpan="2" Visibility="{Binding IsAxisPedalDisplay, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions><ColumnDefinition Width="2.77*" /><ColumnDefinition Width="1.18*" /></Grid.ColumnDefinitions>
            <Border Style="{StaticResource TelemetryCardStyle}" Padding="8,6" Margin="0,0,6,6">
                <r:PedalTraceControl Samples="{Binding PedalTraceSamples}" CurrentTimeSeconds="{Binding CurrentSample.SessionElapsedSeconds}"
                                     ThrottleValue="{Binding ThrottleValue}" BrakeValue="{Binding BrakeValue}" />
            </Border>
            <Grid Grid.Column="1" Margin="0,0,0,6">
                <Grid.RowDefinitions><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions>
                <Border Style="{StaticResource TelemetryCardStyle}" Margin="0,0,3,3" Padding="8"><StackPanel><TextBlock Text="单圈时间" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding LapTimeText}" FontSize="15" Margin="0,7,0,0" /></StackPanel></Border>
                <Border Grid.Column="1" Style="{StaticResource TelemetryCardStyle}" Margin="3,0,0,3" Padding="8"><StackPanel><TextBlock Text="与最佳圈差" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding BestDeltaText}" FontSize="17" Foreground="{StaticResource SuccessGreenBrush}" Margin="0,6,0,0" /></StackPanel></Border>
                <Border Grid.Row="1" Style="{StaticResource TelemetryCardStyle}" Margin="0,3,3,0" Padding="8"><StackPanel><TextBlock Text="横向 G" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding LateralGText}" FontSize="14" Margin="0,7,0,0" /></StackPanel></Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource TelemetryCardStyle}" Margin="3,3,0,0" Padding="8"><StackPanel><TextBlock Text="纵向 G" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding LongitudinalGText}" FontSize="14" Margin="0,7,0,0" /></StackPanel></Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="156" /><ColumnDefinition Width="*" /><ColumnDefinition Width="92" />
            </Grid.ColumnDefinitions>
            <Grid Margin="0,0,6,0">
                <Grid.RowDefinitions><RowDefinition /><RowDefinition /></Grid.RowDefinitions>
                <Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions>
                <Border Style="{StaticResource TelemetryCardStyle}" Padding="7,5" Margin="0,0,3,3">
                    <StackPanel><TextBlock Text="ABS" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding AbsLevelText}" FontSize="21" HorizontalAlignment="Center" Margin="0,3,0,0" /><TextBlock Text="{Binding AbsStatusText}" Foreground="{StaticResource BlueHighlightBrush}" FontSize="8" HorizontalAlignment="Center" /></StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource TelemetryCardStyle}" Padding="7,5" Margin="3,0,0,3">
                    <StackPanel><TextBlock Text="TC" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding TcLevelText}" FontSize="21" HorizontalAlignment="Center" Margin="0,3,0,0" /><TextBlock Text="{Binding TcStatusText}" Foreground="{StaticResource BlueHighlightBrush}" FontSize="8" HorizontalAlignment="Center" /></StackPanel>
                </Border>
                <Border Grid.Row="1" Style="{StaticResource TelemetryCardStyle}" Padding="7,5" Margin="0,3,3,0">
                    <StackPanel><TextBlock Text="ERS" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding ErsBatteryText}" FontSize="18" HorizontalAlignment="Center" Margin="0,4,0,0" /><TextBlock Text="{Binding ErsStateText}" Foreground="{StaticResource SuccessGreenBrush}" FontSize="8" HorizontalAlignment="Center" /></StackPanel>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource TelemetryCardStyle}" Padding="7,5" Margin="3,3,0,0">
                    <StackPanel><TextBlock Text="BB" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding BrakeBiasText}" FontSize="16" HorizontalAlignment="Center" Margin="0,5,0,0" /><TextBlock Text="{Binding BrakeBiasDetailText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="7" HorizontalAlignment="Center" /></StackPanel>
                </Border>
            </Grid>

            <Border Grid.Column="1" Style="{StaticResource TelemetryCardStyle}" Padding="8,6" Margin="0,0,6,0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Grid>
                        <TextBlock Text="轮胎 | 刹车盘" Style="{StaticResource TelemetryLabelStyle}" />
                        <TextBlock Text="胎压 · 胎温 · 盘温" HorizontalAlignment="Right" FontSize="8"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Grid>
                    <r:TireBrakeStatusControl Grid.Row="1" Margin="0,3,0,0"
                                              Wheels="{Binding CurrentSample.Wheels, Mode=OneWay}"
                                              FrontCompound="{Binding CurrentSample.FrontTireCompound, Mode=OneWay}"
                                              RearCompound="{Binding CurrentSample.RearTireCompound, Mode=OneWay}"
                                              ToolTip="外侧圆环：轮胎完整度与配方；中间自上而下：胎压、胎温、刹车盘温度" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource TelemetryCardStyle}">
                <StackPanel><TextBlock Text="燃油" Style="{StaticResource TelemetryLabelStyle}" /><TextBlock Text="{Binding FuelText}" FontSize="21" HorizontalAlignment="Center" Margin="0,17,0,0" /><TextBlock Text="预计剩余" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" FontSize="9" Margin="0,8,0,0" /><TextBlock Text="{Binding FuelRemainingLapsText}" HorizontalAlignment="Center" FontSize="13" /></StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
